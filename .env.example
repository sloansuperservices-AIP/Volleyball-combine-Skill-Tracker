# Application
APP_ENV=development
SECRET_KEY=change-me-in-production
ALLOWED_ORIGINS=http://localhost:3000

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=volleyball_tracker
POSTGRES_USER=vb_user
POSTGRES_PASSWORD=change-me

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=86400          # 24h result cache

# MinIO / S3
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me
MINIO_BUCKET_RAW=raw-uploads
MINIO_BUCKET_PROCESSED=processed-videos
MINIO_BUCKET_ARCHIVE=archive
MINIO_USE_SSL=false

# Vision Worker
VISION_FRAME_SAMPLE_RATE=3    # Process every Nth frame (1 = all frames)
VISION_BATCH_SIZE=16          # Frames per inference batch
VISION_CONFIDENCE_THRESHOLD=0.5
MEDIAPIPE_MODEL_COMPLEXITY=1  # 0=lite, 1=full, 2=heavy

# Video Processing
FFMPEG_THREADS=4
HLS_SEGMENT_DURATION=6        # seconds per .ts segment
VIDEO_RENDITIONS=360p,720p,1080p
VIDEO_MAX_UPLOAD_MB=2048      # 2GB max upload

# Celery
CELERY_CONCURRENCY_VISION=2   # GPU workers per node
CELERY_CONCURRENCY_VIDEO=4    # CPU workers per node
CELERY_TASK_SOFT_TIMEOUT=300  # 5 min
CELERY_TASK_HARD_TIMEOUT=600  # 10 min
